{
  "manifest_version": 3,
  "name": "Spacecamp",
  "version": "1.3.2",
  "description": "Extra project management power for Basecamp 3 and Timechimp users.",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": [ "https://3.basecamp.com/*", "https://app.timechimp.com/*", "https://secure.helpscout.net/conversation/*"],
      "js": ["contentScript.js", "jquery-2.0.2.min.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": "icon.png"
  }
}